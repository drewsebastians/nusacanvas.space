{
  "name": "indonesian-map-tools",
  "version": "0.9.0",
  "private": true,
  "description": "Static browser app for coloring Indonesia kabupaten/kota regions.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/wrangler-command.js dev",
    "dev:static": "node scripts/serve-static.js . 8000",
    "data:verify-sources": "node scripts/data-pipeline.js verify-sources",
    "data:license": "node scripts/data-pipeline.js license",
    "data:normalize": "node scripts/data-pipeline.js normalize",
    "data:match": "node scripts/generate-canonical-registry.js",
    "data:simplify": "node scripts/data-pipeline.js simplify",
    "data:build-registry": "node scripts/generate-canonical-registry.js",
    "data:build-manifest": "node scripts/data-pipeline.js build-manifest",
    "data:test": "node scripts/data-pipeline.js test",
    "data:diff": "node scripts/data-pipeline.js diff",
    "data:reproduce": "node scripts/data-pipeline.js reproduce",
    "data:refresh": "node scripts/data-pipeline.js refresh",
    "test:data": "python tests/run_data_tests.py",
    "test:unit": "node --test --test-isolation=none tests/unit/*.test.js",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:e2e:trust": "playwright test tests/e2e/trust.spec.js",
    "test:a11y": "playwright test tests/e2e/a11y.spec.js",
    "test:performance": "node scripts/check-performance-budgets.js",
    "test:content": "node scripts/check-static-content.js",
    "test:security": "node scripts/security-audit.js",
    "measure": "node scripts/measure.js",
    "check": "node scripts/check.js",
    "verify:batch1": "node scripts/verify-batch1.js",
    "deploy": "node scripts/wrangler-command.js deploy",
    "deploy:ci": "wrangler deploy",
    "verify:staging": "node scripts/verify-staging.js https://mapnesia.andrew-sebastian91.workers.dev"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "axe-core": "4.12.1",
    "wrangler": "4.110.0"
  }
}
