{
  "name": "nusacanvas",
  "version": "0.9.0",
  "private": true,
  "description": "NusaCanvas creates clear Indonesia regency and city maps from spreadsheet data in the browser.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "postinstall": "node scripts/build.js",
    "build": "node scripts/build.js",
    "dev": "node scripts/wrangler-command.js dev",
    "dev:static": "node scripts/serve-static.js . 8000",
    "data:verify-sources": "node scripts/data-pipeline.js verify-sources",
    "data:license": "node scripts/data-pipeline.js license",
    "data:normalize": "node scripts/data-pipeline.js normalize",
    "data:match": "node scripts/generate-canonical-registry.js",
    "data:simplify": "node scripts/data-pipeline.js simplify",
    "data:build-registry": "node scripts/generate-canonical-registry.js",
    "data:build-manifest": "node scripts/data-pipeline.js build-manifest",
    "data:test": "node scripts/data-pipeline.js test",
    "data:diff": "node scripts/data-pipeline.js diff",
    "data:reproduce": "node scripts/data-pipeline.js reproduce",
    "data:refresh": "node scripts/data-pipeline.js refresh",
    "test:data": "python tests/run_data_tests.py",
    "test:unit": "node --test --test-isolation=none tests/unit/*.test.js",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:e2e:trust": "playwright test tests/e2e/trust.spec.js",
    "test:a11y": "playwright test tests/e2e/a11y.spec.js",
    "test:performance": "node scripts/check-performance-budgets.js",
    "test:content": "node scripts/check-static-content.js",
    "test:security": "node scripts/security-audit.js",
    "inventory:batch2r": "node scripts/build-batch2r-inventory.js",
    "capture:batch2r:baseline": "playwright test tests/e2e/batch2r-baseline.spec.js --project=chromium-desktop --workers=1",
    "verify:batch2r:preflight": "node scripts/verify-batch2r-preflight.js",
    "preview:batch2r:prototypes": "node scripts/serve-static.js . 4174",
    "verify:batch2r:prototype-isolation": "node scripts/verify-batch2r-prototype-isolation.js",
    "verify:batch2r:prototypes": "playwright test --config=playwright.prototypes.config.js",
    "test:batch2r:public-shell": "playwright test tests/e2e/batch2r-public-shell.spec.js --project=chromium-desktop --workers=1",
    "verify:batch2r:public-shell": "node scripts/verify-batch2r-public-shell.js && npm run test:batch2r:public-shell",
    "test:batch2r:workspace": "playwright test tests/e2e/batch2r-workspace.spec.js --project=chromium-desktop --workers=1",
    "verify:batch2r:workspace": "npm run test:batch2r:workspace && node scripts/verify-batch2r-workspace.js",
    "test:batch2r:guidance": "playwright test tests/e2e/batch2r-guidance.spec.js --project=chromium-desktop --workers=1",
    "test:batch2r:boundary-rendering": "playwright test tests/e2e/batch2r-boundary-rendering.spec.js --workers=1",
    "verify:batch2r:boundary-rendering": "node scripts/verify-batch2r-boundary-rendering.js",
    "test:batch2r:closure": "playwright test tests/e2e/batch2r-closure.spec.js --project=chromium-desktop --project=chromium-mobile --workers=1",
    "verify:batch2r:closure": "node scripts/verify-batch2r-closure.js",
    "audit:terminology": "node scripts/terminology-audit.js",
    "audit:brand-migration": "node scripts/brand-migration-audit.js",
    "measure": "node scripts/measure.js",
    "check": "node scripts/check.js",
    "verify:batch1": "node scripts/brand-migration-audit.js && node scripts/verify-batch1.js",
    "deploy": "node scripts/wrangler-command.js deploy",
    "deploy:ci": "wrangler deploy",
    "verify:production": "node scripts/verify-production.js https://nusacanvas.space"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "axe-core": "4.12.1",
    "wrangler": "4.110.0"
  },
  "dependencies": {
    "read-excel-file": "9.3.1"
  }
}
